---
## Example per-robot config for the optional openai-fallback plugin.
## To enable the plugin, uncomment its stanza in custom/conf/robot.yaml
## and set OPENAI_KEY there as a Parameter.
Config:
  WaitMessages:
  - "hang tight while I work on this"
  - "thinking this through"
  - "working on a reply"
  DrawMessages:
  - "working on an image"
  - "rendering now"
  Profiles:
    "default":
      "params":
        "model": "gpt-4o-mini"
        "temperature": 0.7
      "system": |
        You are a multi-user chatbot assistant for this robot.
        Keep responses concise, useful, and collaborative.
      "max_context": 7168
