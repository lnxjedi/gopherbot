# Copy this file to gcloud.env, edit it, then run:
#   source ./gcloud.env

export PROJECT_ID="your-gcp-project-id"
export REGION="us-central1"

# Project resources created by the helper scripts.
export FIRESTORE_DATABASE_ID="(default)"
export FIRESTORE_COLLECTION="gopherbot-brain"
export TOPIC_ID="gopherbot-chat"
export SUBSCRIPTION_ID="gopherbot-chat-sub"
export SERVICE_ACCOUNT_ID="gopherbot-robot"
export SERVICE_ACCOUNT_KEY_JSON="$HOME/gopherbot-key.json"

# Set this if your org policy requires an explicit Pub/Sub storage region list.
# For a simple setup, using the same region as Firestore is fine.
export PUBSUB_ALLOWED_REGIONS="${REGION}"

# Human-facing robot/app settings used by the README and manual UI steps.
export ROBOT_NAME="Bishop"
export ROBOT_SLASH_COMMAND="/bishop"
export WORKSPACE_TEST_USER="you@example.com"

# Helpful manual UI values.
export ROBOT_DESCRIPTION="DevOps chatbot"
export ROBOT_SUPPORT_URL="https://github.com/your-org/your-robot"
export ROBOT_PRIVACY_URL="https://github.com/your-org/your-robot"
export ROBOT_TERMS_URL="https://github.com/your-org/your-robot"

# Optional local note for where your avatar image lives while you are filling
# in the Marketplace store listing.
export ROBOT_AVATAR_PATH="$HOME/path/to/robot-avatar.png"
