# Copy this file to gcloud.env, edit it, then run:
#   source ./gcloud.env

export PROJECT_ID="your-gcp-project-id"
export REGION="us-central1"

# Project resources created by the helper scripts.
export FIRESTORE_DATABASE_ID="(default)"
export FIRESTORE_COLLECTION="gopherbot-brain"
export TOPIC_ID="gopherbot-chat"
export SUBSCRIPTION_ID="gopherbot-chat-sub"
export SERVICE_ACCOUNT_ID="gopherbot-robot"
export SERVICE_ACCOUNT_KEY_JSON="$HOME/gopherbot-key.json"

# Use a uuid generator to create your own; in google cloud console, 'uuid' will do
# export QUEUE_WEBHOOK_UUID="1104df4c-feeb-43ab-8c85-83663288cea9"

# Human-facing name used by the helper scripts.
export ROBOT_NAME="Bishop"
