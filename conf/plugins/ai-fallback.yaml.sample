---
## Default configuration for the optional ai-fallback plugin.
## This file is merged with the plugin's internal defaults and can be
## overridden by custom/conf/plugins/ai-fallback.yaml.
Config:
  ## Human-readable provider name used in errors/logs.
  ProviderName: "AI provider"
  ## Base URL for a chat-completions-compatible API, e.g.:
  ## "https://generativelanguage.googleapis.com/v1beta/openai/"
  APIBaseURL: ""
  ## Optional exact chat completions URL. Overrides APIBaseURL when set.
  ChatCompletionsURL: ""
  ## Optional provider-specific organization/project header name. Leave empty
  ## for providers that only require bearer-token authentication.
  OrganizationHeader: ""
  ## Immediate acknowledgment that the prompt was received.
  ## Set to "" to disable.
  HeardNotice: "_(working on a reply...)_"
  DrawMessages:
  - "working on an image"
  - "drawing now"
  - "rendering your request"
  ## Streaming markers for multipart replies.
  MultipartStartNotice: "_(replying in parts...)_"
  MultipartContinueNotice: "_(continuing...)_"
  MultipartEndNotice: "_(end reply)_"
  MultipartInterruptedNotice: "_(reply interrupted)_"
  CompactionTriggerTokens: 6144
  MaxRecentExchanges: 12
  SummaryBudgetTokens: 768
  EnableModelCompaction: false
  Profiles:
    "default":
      "params":
        "model": "" # e.g. "gemini-2.5-flash", "claude-sonnet-4-5", provider-specific
        "temperature": 0.7
      "SystemPrompt":
        "Standard": |
          You are an AI assistant participating in a multi-user chat conversation.
          Messages are provided with speaker prefixes like "username says: ...".
          Use these prefixes to identify who is speaking.
          When replying to a specific person, address them as "@username" naturally.
          If users are mainly talking to each other and no bot response is needed, keep your response minimal and non-intrusive, or reply with "(no response)".
          Do not echo speaker prefixes unless it helps clarity.
        "Custom": |
          You are helpful, concise, and collaborative.
      "max_context": 7168
