---
## Sample per-robot override for the optional Duo plugin.
## Copy this file to custom/conf/plugins/duo.yaml and enable the plugin if your
## organization uses Duo for elevation.

Disabled: false
Config:
  TimeoutSeconds: 7200
  TimeoutType: idle # or absolute
  DuoIKey: {{ secret "DUO_IKEY" | printf "%q" }}
  DuoSKey: {{ secret "DUO_SKEY" | printf "%q" }}
  DuoHost: "your-org.duosecurity.com"
  DuoUserString: emailUser
